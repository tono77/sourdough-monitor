rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Sessions: authenticated users can read and write (e.g. for calibration)
    match /sesiones/{sessionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Measurements: authenticated users can read, no client writes normally
    match /sesiones/{sessionId}/mediciones/{measurementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;  // For future feedback/editing
    }

    // Status document: authenticated users can read
    match /status/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
